{
  "name": "dctf-mpc",
  "version": "1.0.0",
  "description": "Sistema de análise e processamento de dados DCTF com interface web moderna",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "nodemon --watch src --ext ts,js --exec ts-node src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:connection": "ts-node src/scripts/test-connection.ts",
    "import:clientes": "ts-node src/scripts/import-clientes.ts",
    "update:clientes-nome": "ts-node src/scripts/update-clientes-nome.ts",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "dctf",
    "fiscal",
    "análise",
    "typescript",
    "nodejs",
    "supabase"
  ],
  "author": "Bruno",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "@types/compression": "^1.8.1",
    "@types/express-rate-limit": "^5.1.3",
    "@types/morgan": "^1.9.10",
    "@types/xlsx": "^0.0.35",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "csv-parser": "^3.0.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.0",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "pdfkit": "^0.13.0",
    "socket.io": "^4.8.1",
    "task-master-ai": "^0.31.2",
    "winston": "^3.11.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.10.0",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.0",
    "rimraf": "^5.0.5",
    "socket.io-client": "^4.8.1",
    "supertest": "^7.1.4",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bruno/dctf-mpc.git"
  },
  "bugs": {
    "url": "https://github.com/bruno/dctf-mpc/issues"
  },
  "homepage": "https://github.com/bruno/dctf-mpc#readme"
}
