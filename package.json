{
  "name": "dctf-mpc",
  "version": "1.0.0",
  "description": "Sistema de análise e processamento de dados DCTF com interface web moderna",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:production": "npm run clean && npm ci --omit=dev && npm run build",
    "dev": "nodemon --watch src --ext ts,js --exec \"ts-node --transpile-only --files src/index.ts\"",
    "start": "echo '⚠️  ATENÇÃO: npm start usa arquivos compilados (dist/). Use npm run dev para desenvolvimento!' && node dist/index.js",
    "start:production": "NODE_ENV=production node dist/index.js",
    "deploy:dev": "node scripts/deploy-development.js || bash scripts/deploy-development.sh",
    "deploy:prod": "node scripts/deploy-production.js || bash scripts/deploy-production.sh",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:connection": "ts-node src/scripts/test-connection.ts",
    "test:mysql-connection": "ts-node src/scripts/test-mysql-connection.ts",
    "mysql:demo": "ts-node src/scripts/mysql-demo.ts",
    "import:clientes": "ts-node src/scripts/import-clientes.ts",
    "update:clientes-nome": "ts-node src/scripts/update-clientes-nome.ts",
    "update:codigo-sci": "ts-node src/scripts/update-clientes-codigo-sci.ts",
    "verify:duplicados": "ts-node src/scripts/verificar-clientes-duplicados.ts",
    "verify:razoes-incorretas": "ts-node src/scripts/verificar-razoes-sociais-incorretas.ts",
    "fix:razoes-sociais": "ts-node src/scripts/corrigir-razoes-sociais-cnpj.ts",
    "identify:registros-incorretos": "ts-node src/scripts/identificar-registros-incorretos.ts",
    "clean:duplicados": "ts-node src/scripts/limpar-registros-duplicados.ts",
    "revert:dctf-hoje": "ts-node src/scripts/revert-dctf-declaracoes-hoje.ts",
    "remove:cnpj-na-razao": "ts-node src/scripts/remover-registros-com-cnpj-na-razao.ts",
    "remove:clientes-recentes": "ts-node src/scripts/remover-clientes-recentes.ts",
    "verify:datas-criacao": "ts-node src/scripts/verificar-datas-criacao-clientes.ts",
    "fix:razao-social": "ts-node src/scripts/verificar-e-corrigir-razao-social.ts",
    "update:socios-zerados": "ts-node src/scripts/atualizar-socios-zerados.ts",
    "create:host-dados": "ts-node src/scripts/create-host-dados-table.ts",
    "create:banco-horas-table": "ts-node src/scripts/create-banco-horas-table.ts",
    "create:sped-v2-legal-docs": "ts-node src/scripts/create-sped-v2-legal-documents-tables.ts",
    "create:irpf-producao-tables": "ts-node src/scripts/create-irpf-producao-tables.ts",
    "migrate:irpf-producao": "ts-node src/scripts/run-irpf-producao-migrations.ts",
    "workers:irpf-producao": "ts-node src/scripts/run-irpf-producao-workers.ts",
    "migrate:sitf-extracted": "ts-node src/scripts/run-sitf-migration.ts",
    "migrate:teste-png": "ts-node src/scripts/run-teste-png-migration.ts",
    "verify:ocr-vs-mysql": "ts-node src/scripts/verificar-ocr-vs-mysql-dctf.ts",
    "migrate:clientes-receitaws": "ts-node src/scripts/migrate-clientes-receitaws-fields.ts",
    "verify:clientes-schema": "ts-node src/scripts/verify-clientes-schema.ts",
    "fix:clientes-schema": "ts-node src/scripts/fix-clientes-schema.ts",
    "test:clientes-persistence": "ts-node src/scripts/test-clientes-persistence.ts",
    "preencher:rede-pastas": "ts-node src/scripts/preencher-rede-por-pastas-csv.ts",
    "verificar:sem-pasta-rede": "ts-node src/scripts/verificar-clientes-sem-pasta-rede.ts",
    "verificar:sem-regime-tributario": "ts-node src/scripts/verificar-clientes-sem-regime-tributario.ts",
    "adicionar:fiscal-2026-rede": "ts-node src/scripts/adicionar-fiscal-2026-pasta-rede.ts",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "clean": "rimraf dist",
    "clean:cache": "rimraf node_modules/.cache ts-node-cache .ts-node",
    "prebuild": "npm run clean",
    "type-check": "tsc --noEmit",
    "lint:unused": "knip",
    "deps:check": "depcheck"
  },
  "keywords": [
    "dctf",
    "fiscal",
    "análise",
    "typescript",
    "nodejs",
    "supabase"
  ],
  "author": "Bruno",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "@types/compression": "^1.8.1",
    "@types/express-rate-limit": "^5.1.3",
    "@types/morgan": "^1.9.10",
    "@types/nodemailer": "^7.0.9",
    "@types/xlsx": "^0.0.35",
    "axios": "^1.13.2",
    "bullmq": "^5.69.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "csv-parser": "^3.0.0",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.0",
    "fast-xml-parser": "^5.3.7",
    "helmet": "^7.1.0",
    "ioredis": "^5.9.3",
    "joi": "^17.11.0",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.15.3",
    "nodemailer": "^7.0.13",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.13.0",
    "sharp": "^0.33.5",
    "socket.io": "^4.8.1",
    "task-master-ai": "^0.18.0",
    "tesseract.js": "^5.1.1",
    "uuid": "^13.0.0",
    "winston": "^3.11.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.19.25",
    "@types/pdfkit": "^0.17.3",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "depcheck": "^1.4.7",
    "eslint": "^8.54.0",
    "jest": "^30.2.0",
    "knip": "^5.84.1",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.0",
    "rimraf": "^5.0.5",
    "socket.io-client": "^4.8.1",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bruno/dctf-mpc.git"
  },
  "bugs": {
    "url": "https://github.com/bruno/dctf-mpc/issues"
  },
  "homepage": "https://github.com/bruno/dctf-mpc#readme"
}
